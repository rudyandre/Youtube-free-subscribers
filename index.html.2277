<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WorldCup 2026 Hub - Portal & Live Center</title>
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- React & React DOM CDN -->
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  
  <!-- Babel CDN (agar browser bisa membaca JSX) -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body {
      background-color: #0f172a;
      color: #f8fafc;
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect } = React;

    function App() {
      const [activeTab, setActiveTab] = useState('standings');

      // Data Mockup Piala Dunia 2026
      const liveMatches = [
        {
          id: "m1",
          homeTeam: "Meksiko",
          awayTeam: "Afrika Selatan",
          homeScore: 2,
          awayScore: 1,
          minute: "78'",
          status: "LIVE",
          group: "Grup A"
        },
        {
          id: "m2",
          homeTeam: "Amerika Serikat",
          awayTeam: "Denmark",
          homeScore: 0,
          awayScore: 0,
          minute: "34'",
          status: "LIVE",
          group: "Grup A"
        }
      ];

      const standings = {
        "Grup A": [
          { pos: 1, team: "Meksiko", p: 3, w: 2, d: 1, l: 0, gd: "+3", pts: 7 },
          { pos: 2, team: "Amerika Serikat", p: 3, w: 2, d: 0, l: 1, gd: "+2", pts: 6 },
          { pos: 3, team: "Afrika Selatan", p: 3, w: 1, d: 0, l: 2, gd: "-1", pts: 3 },
          { pos: 4, team: "Denmark", p: 3, w: 0, d: 1, l: 2, gd: "-4", pts: 1 }
        ],
        "Grup B": [
          { pos: 1, team: "Kanada", p: 3, w: 2, d: 1, l: 0, gd: "+4", pts: 7 },
          { pos: 2, team: "Italia", p: 3, w: 2, d: 0, l: 1, gd: "+2", pts: 6 },
          { pos: 3, team: "Nigeria", p: 3, w: 1, d: 0, l: 2, gd: "-2", pts: 3 },
          { pos: 4, team: "Jepang", p: 3, w: 0, d: 1, l: 2, gd: "-4", pts: 1 }
        ]
      };

      const topScorers = [
        { rank: 1, player: "Kylian Mbappé", team: "Prancis", goals: 5, assists: 2 },
        { rank: 2, player: "Vinícius Jr.", team: "Brasil", goals: 4, assists: 3 },
        { rank: 3, player: "Julián Álvarez", team: "Argentina", goals: 4, assists: 1 },
        { rank: 4, player: "Bukayo Saka", team: "Inggris", goals: 3, assists: 2 }
      ];

      return (
        <div className="min-h-screen flex flex-col max-w-5xl mx-auto p-4 md:p-6">
          {/* Header */}
          <header className="border-b border-slate-800 pb-4 mb-6 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div className="flex items-center gap-3">
              <span className="text-3xl">🏆</span>
              <div>
                <h1 className="text-2xl font-black tracking-tight text-amber-400">WorldCup 2026 Hub</h1>
                <p className="text-xs text-slate-400">Portal & Live Match Center Official</p>
              </div>
            </div>
            <div className="flex items-center gap-2 bg-red-950/50 border border-red-500/30 px-3 py-1.5 rounded-full">
              <span className="w-2.5 h-2.5 bg-red-500 rounded-full animate-ping"></span>
              <span className="text-xs font-bold text-red-400 tracking-wider">LIVE MATCH CENTER</span>
            </div>
          </header>

          {/* Hero Banner / Live Matches */}
          <section className="mb-8">
            <h2 className="text-lg font-bold mb-3 text-slate-300 flex items-center gap-2">
              <span>🔴</span> Pertandingan Berlangsung
            </h2>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              {liveMatches.map((match) => (
                <div key={match.id} className="bg-slate-800/80 backdrop-blur p-4 rounded-xl border border-slate-700/60 flex justify-between items-center shadow-lg">
                  <div>
                    <span className="text-[10px] bg-red-600 text-white px-2 py-0.5 rounded font-black uppercase tracking-wider">{match.minute}</span>
                    <p className="font-bold text-base mt-1.5 text-slate-100">{match.homeTeam} vs {match.awayTeam}</p>
                    <p className="text-xs text-slate-400">{match.group}</p>
                  </div>
                  <div className="text-2xl font-black text-amber-400 bg-slate-900/80 px-4 py-2 rounded-lg border border-slate-700">
                    {match.homeScore} - {match.awayScore}
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* Navigation Tabs */}
          <div className="flex border-b border-slate-800 mb-6 gap-2">
            <button 
              onClick={() => setActiveTab('standings')}
              className={`pb-3 px-4 text-sm font-bold border-b-2 transition-all ${activeTab === 'standings' ? 'border-amber-400 text-amber-400' : 'border-transparent text-slate-400 hover:text-slate-200'}`}
            >
              Klasemen Grup
            </button>
            <button 
              onClick={() => setActiveTab('topscorers')}
              className={`pb-3 px-4 text-sm font-bold border-b-2 transition-all ${activeTab === 'topscorers' ? 'border-amber-400 text-amber-400' : 'border-transparent text-slate-400 hover:text-slate-200'}`}
            >
              Top Skor (Golden Boot)
            </button>
          </div>

          {/* Tab Content: Standings */}
          {activeTab === 'standings' && (
            <section className="space-y-6">
              {Object.keys(standings).map((groupKey) => (
                <div key={groupKey} className="bg-slate-800/50 rounded-xl p-4 border border-slate-700/50 shadow-sm">
                  <h3 className="font-bold text-amber-400 mb-3 text-base flex items-center gap-2">
                    <span>📌</span> {groupKey}
                  </h3>
                  <div className="overflow-x-auto">
                    <table className="w-full text-left text-sm">
                      <thead>
                        <tr className="border-b border-slate-700 text-slate-400 text-xs uppercase">
                          <th className="p-2">#</th>
                          <th className="p-2">Tim</th>
                          <th className="p-2">Main</th>
                          <th className="p-2">SG</th>
                          <th className="p-2">Poin</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-slate-700/40">
                        {standings[groupKey].map((row) => (
                          <tr key={row.team} className="hover:bg-slate-700/30 transition-colors">
                            <td className="p-2 font-bold text-slate-400">{row.pos}</td>
                            <td className="p-2 font-semibold text-slate-100">{row.team}</td>
                            <td className="p-2 text-slate-300">{row.p}</td>
                            <td className="p-2 text-slate-300">{row.gd}</td>
                            <td className="p-2 font-bold text-amber-400">{row.pts}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              ))}
            </section>
          )}

          {/* Tab Content: Top Scorers */}
          {activeTab === 'topscorers' && (
            <section className="bg-slate-800/50 rounded-xl p-4 border border-slate-700/50 shadow-sm">
              <div className="overflow-x-auto">
                <table className="w-full text-left text-sm">
                  <thead>
                    <tr className="border-b border-slate-700 text-slate-400 text-xs uppercase">
                      <th className="p-3">Peringkat</th>
                      <th className="p-3">Pemain</th>
                      <th className="p-3">Tim</th>
                      <th className="p-3">Gol</th>
                      <th className="p-3">Assist</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-700/40">
                    {topScorers.map((player) => (
                      <tr key={player.player} className="hover:bg-slate-700/30 transition-colors">
                        <td className="p-3 font-bold text-amber-400">#{player.rank}</td>
                        <td className="p-3 font-semibold text-slate-100">{player.player}</td>
                        <td className="p-3 text-slate-300">{player.team}</td>
                        <td className="p-3 font-black text-amber-400">{player.goals}</td>
                        <td className="p-3 text-slate-300">{player.assists}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          )}

          {/* Footer */}
          <footer className="mt-auto pt-8 pb-4 text-center text-xs text-slate-500 border-t border-slate-800">
            © 2026 WorldCup Hub. Portal Informasi Sepak Bola Dunia.
          </footer>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
